From c1058cc70867983a0265d06a747ae91e6107ba9c Mon Sep 17 00:00:00 2001
From: edge-provider-sdk <edge-provider-sdk@example.com>
Date: Wed, 13 May 2026 16:32:54 +0100
Subject: [PATCH 1/3] site-enum-permissive: replace 3 site (str, Enum) classes
 with permissive str aliases
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Affected:
  - models/create_serverop.py: CreateServerServersSite
  - models/post_vpn_sessionop.py: PostVpnSessionVpnSessionsSite
  - models/create_virtual_networkop.py: CreateVirtualNetworkPrivateNetworksSite

Adds _ORIGINAL_SITES tuple in models/create_serverop.py so the wrapper's
'latitude' provider can still do strict validation against the canonical 18
site slugs. See SPEC.md §3, §4.

diff --git a/src/latitudesh_python_sdk/models/create_serverop.py b/src/latitudesh_python_sdk/models/create_serverop.py
index f28df5a..2c024ef 100644
--- a/src/latitudesh_python_sdk/models/create_serverop.py
+++ b/src/latitudesh_python_sdk/models/create_serverop.py
@@ -42,27 +42,14 @@ class CreateServerServersPlan(str, Enum):
     S3_LARGE_X86 = "s3-large-x86"
 
 
-class CreateServerServersSite(str, Enum):
-    r"""The site slug to deploy the server"""
-
-    ASH = "ASH"
-    BUE = "BUE"
-    CHI = "CHI"
-    DAL = "DAL"
-    FRA = "FRA"
-    LAX = "LAX"
-    LON = "LON"
-    MEX = "MEX"
-    MEX2 = "MEX2"
-    MIA = "MIA"
-    MIA2 = "MIA2"
-    NYC = "NYC"
-    SAO = "SAO"
-    SAO2 = "SAO2"
-    SGP = "SGP"
-    SYD = "SYD"
-    TYO = "TYO"
-    TYO2 = "TYO2"
+# edge-provider-sdk patch: original Latitude site slugs preserved for strict
+# validation when provider="latitude". Permissive alias below accepts any string
+# so digital-frontier and other Latitude-shaped providers can supply their own.
+_ORIGINAL_SITES = (
+    "ASH", "BUE", "CHI", "DAL", "FRA", "LAX", "LON", "MEX", "MEX2",
+    "MIA", "MIA2", "NYC", "SAO", "SAO2", "SGP", "SYD", "TYO", "TYO2",
+)
+CreateServerServersSite = str
 
 
 class CreateServerServersOperatingSystem(str, Enum):
diff --git a/src/latitudesh_python_sdk/models/create_virtual_networkop.py b/src/latitudesh_python_sdk/models/create_virtual_networkop.py
