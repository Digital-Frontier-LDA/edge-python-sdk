--- a/src/latitudesh_python_sdk/models/create_virtual_networkop.py
+++ b/src/latitudesh_python_sdk/models/create_virtual_networkop.py
@@ -12,27 +12,9 @@ class CreateVirtualNetworkPrivateNetworksType(str, Enum):
     VIRTUAL_NETWORK = "virtual_network"
 
 
-class CreateVirtualNetworkPrivateNetworksSite(str, Enum):
-    r"""Site ID or slug"""
-
-    ASH = "ASH"
-    BUE = "BUE"
-    CHI = "CHI"
-    DAL = "DAL"
-    FRA = "FRA"
-    LAX = "LAX"
-    LON = "LON"
-    MEX = "MEX"
-    MEX2 = "MEX2"
-    MIA = "MIA"
-    MIA2 = "MIA2"
-    NYC = "NYC"
-    SAO = "SAO"
-    SAO2 = "SAO2"
-    SGP = "SGP"
-    SYD = "SYD"
-    TYO = "TYO"
-    TYO2 = "TYO2"
+# edge-provider-sdk patch: permissive alias — accepts any string. Canonical
+# Latitude site list lives in models.create_serverop._ORIGINAL_SITES.
+CreateVirtualNetworkPrivateNetworksSite = str
 
 
 class CreateVirtualNetworkPrivateNetworksAttributesTypedDict(TypedDict):
